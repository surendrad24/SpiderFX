<%include file="HEADER.tmpl"/>
<script src="${docroot}/static/js/spiderfoot.newscan.js"></script>

<div class="hx-page-wrap">
  <h2 class="hx-page-title">New Scan</h2>
  <form class="form" action='${docroot}/startscan' method='POST'>
    <div class="row">
      <div class="col-md-8">
        <div class="panel panel-default hx-card">
          <div class="panel-heading hx-heading"><i class="glyphicon glyphicon-screenshot"></i>&nbsp;Scan Name & Targets</div>
          <div class="panel-body">
            <div class="row">
              <div class='col-sm-6'>
                <label for="scanname">Scan Name</label>
                <div class="input-group" style='padding-bottom: 10px'>
                  <input class='form-control' type="text" id="scanname" name="scanname" value="${scanname}" placeholder="The name of this scan.">
                </div>
              </div>
              <div class='col-sm-6'>
                <label for="scantarget">Scan Target</label>
                <div class="input-group" style='padding-bottom: 10px'>
                  <input class='form-control' type="text" value="${scantarget}" id="scantarget" name="scantarget" placeholder="The target of your scan.">
                </div>
              </div>
            </div>
            <div class='alert alert-info hx-help-box'>
              <i class='glyphicon glyphicon-info-sign'></i>&nbsp;
              Supported targets: Domain, IP, hostname, subnet, email, phone, human name, username, ASN and more.
            </div>
          </div>
        </div>

        <div class="panel panel-default hx-card">
          <div class="panel-heading hx-heading"><i class="glyphicon glyphicon-refresh"></i>&nbsp;Iteration</div>
          <div class="panel-body">
            <div class="hx-iter-item">
              <label class="hx-switch"><input type="checkbox" checked disabled><span class="hx-switch-slider"></span></label>
              <div class="hx-iter-text"><strong>Entity iteration</strong><br>Recursively gather related entities discovered during scan.</div>
            </div>
            <div class="hx-iter-item">
              <label class="hx-switch"><input type="checkbox" disabled><span class="hx-switch-slider"></span></label>
              <div class="hx-iter-text"><strong>Affiliate iteration</strong><br>Include affiliate entities when discovered.</div>
            </div>
            <div class="hx-iter-item">
              <label class="hx-switch"><input type="checkbox" disabled><span class="hx-switch-slider"></span></label>
              <div class="hx-iter-text"><strong>Co-host iteration</strong><br>Include co-host findings discovered from host intelligence.</div>
            </div>
            <div class="hx-iter-item">
              <label class="hx-switch"><input type="checkbox" disabled><span class="hx-switch-slider"></span></label>
              <div class="hx-iter-text"><strong>Human name iteration</strong><br>Expand from discovered people identities where available.</div>
            </div>
          </div>
        </div>

        <div class="panel panel-default hx-card">
          <div class="panel-heading hx-heading"><i class="glyphicon glyphicon-flash"></i>&nbsp;Modules</div>
          <div class="panel-body" style="padding-bottom:0">
            <div class="control-group">
              <ul class='nav nav-tabs hx-tabs'>
                <li id='usetab' class="active"><a href='#'>By Use Case</a></li>
                <li id='typetab'><a href='#'>By Required Data</a></li>
                <li id='moduletab'><a href='#'>By Module</a></li>
                <div class='btn-group-sm pull-right' role="group" id='selectors' style='display: none'>
                  <button id="btn-select-all" type="button" class="btn btn-info">Select All</button>&nbsp;&nbsp;
                  <button id="btn-deselect-all" type="button" class="btn btn-info">De-Select All</button>
                </div>
              </ul>
              <table class="table table-striped table-condensed" id="usetable">
                <tr><td style='width: 50px'><input type=radio name='usecase' value='all' id="usecase_all" checked></td><td>All</td><td><b>Get anything and everything about the target.</b><br><br>All SpiderFoot modules will be enabled (slow) but every possible piece of information about the target will be obtained and analysed.<br><br></td></tr>
                <tr><td style='width: 50px'><input type=radio name='usecase' value='Footprint' id="usecase_footprint"></td><td>Footprint</td><td><b>Understand what information this target exposes to the Internet.</b><br><br>Gain an understanding about the target's network perimeter, associated identities and other information that is obtained through a lot of web crawling and search engine use.<br><br></td></tr>
                <tr><td style='width: 50px'><input type=radio name='usecase' value='Investigate' id="usecase_investigate"></td><td>Investigate</td><td><b>Best for when you suspect the target to be malicious but need more information.</b><br><br>Basic footprinting plus intelligence and blacklist sources focused on risk indicators.<br><br></td></tr>
                <tr><td style='width: 50px'><input type=radio name='usecase' value='Passive' id="usecase_passive"></td><td>Passive</td><td><b>When you do not want the target to suspect investigation.</b><br><br>Only modules that avoid directly touching the target are enabled.</td></tr>
                <tr><td style='width: 50px'><input type=radio name='usecase' value='DeepRecon' id="usecase_deeprecon"></td><td>Deep Recon</td><td><b>High-coverage recon pipeline with custom ProjectDiscovery/Kali-style tools.</b><br><br>Enables an opinionated module chain for subdomain discovery, DNS enrichment, service discovery, web crawling/history, TLS collection and vulnerability checks.</td></tr>
              </table>

              <table class="table table-striped table-condensed" id="moduletable" style="display: none">
                <%
                modlist = dict()
                for item in modules:
                    modlist[modules[item]['name']] = item
                %>
                % for it in sorted(modlist, key=lambda v: v.upper()):
                    <% item = modlist[it] %>
                    <% keylist = dict((k, v) for k, v in modules[item]['opts'].items() if not k.startswith('_')) %>
                    <% keyicon = "" %>
                    % if len(keylist) > 0:
                        <% apikeylist = dict((k, v) for k, v in modules[item]['opts'].items() if k.find("api_key") >= 0) %>
                        <%
                        if len(apikeylist) > 0:
                            keyicon = "&nbsp;&nbsp;<i class=\"glyphicon glyphicon-lock\" rel='tooltip' title='Needs API key'></i>"
                        %>
                    % endif

                    % if item != "sfp__stor_db" and item != "sfp__stor_stdout":
                        <tr><td><input type=checkbox id="module_${item}" checked></td><td>${modules[item]['name']}${keyicon}</td><td>${modules[item]['descr']}</td></tr>
                    % endif
                % endfor
              </table>
              <table class="table table-striped table-condensed" id="typetable" style="display: none">
                <% count = 0 %>
                % for item in sorted(types):
                    % if count % 2 == 0:
                        <tr>
                    % endif
                    <td><input type=checkbox id="type_${item[1]}" checked></td><td>${item[0]}</td>
                    % if not count % 2 == 0:
                        </tr>
                    % endif
                    <% count = count + 1 %>
                % endfor
              </table>
            </div>
          </div>
        </div>

        <div class="panel panel-default hx-card">
          <div class="panel-heading hx-heading"><i class="glyphicon glyphicon-cog"></i>&nbsp;Options</div>
          <div class="panel-body">
            <div class="controls">
              <input type=hidden id='modulelist' name='modulelist' value=''>
              <input type=hidden id='typelist' name='typelist' value=''>
              <button id="btn-run-scan" class="btn btn-success hx-run-btn"><i class="glyphicon glyphicon-play"></i>&nbsp;Run Scan Now</button>
            </div>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="panel panel-default hx-card">
          <div class="panel-heading hx-heading"><i class="glyphicon glyphicon-list-alt"></i>&nbsp;Professional Subscription</div>
          <div class="panel-body">
            <table class="table table-condensed hx-sub-table">
              <tr><td>Scans this month (limit)</td><td class="text-right"><strong>${sidebar.get('scans_this_month', 0)} (${sidebar.get('scan_limit', 999)})</strong></td></tr>
              <tr><td>Individual scan duration limit</td><td class="text-right"><strong>${sidebar.get('scan_duration_limit', '48 hours')}</strong></td></tr>
              <tr><td>Maximum targets per scan</td><td class="text-right"><strong>${sidebar.get('max_targets_per_scan', 1024)}</strong></td></tr>
              <tr><td>Scan data retention</td><td class="text-right"><strong>${sidebar.get('data_retention_days', 180)} days</strong></td></tr>
            </table>
          </div>
        </div>

        <div class="panel panel-default hx-card">
          <div class="panel-heading hx-heading"><i class="glyphicon glyphicon-lock"></i>&nbsp;API Keys</div>
          <div class="panel-body text-center">
            <%
              api_total = sidebar.get('api_total', 0)
              api_configured = sidebar.get('api_configured', 0)
              pct = 0
              if api_total > 0:
                  pct = int((float(api_configured) / float(api_total)) * 100)
            %>
            <div class="hx-donut" style="--p:${pct}"><span>${pct}%</span></div>
            <p class="help-block" style="font-size:22px;color:#1fa9d6">${api_configured}</p>
            <p>You have <strong>${api_configured}</strong> out of <strong>${api_total}</strong> API keys configured.</p>
          </div>
        </div>
      </div>
    </div>
  </form>
</div>

<script type='text/javascript'>
  if ("${selectedmods}" != "") {
          switchTab("module");

          $("input[id^=module_]").each(function(id, obj) {
              if ("${selectedmods}".indexOf(obj.id.replace("module_", "")) >= 0) {
                  $("#" + obj.id).attr("checked", true);
              } else {
                  $("#" + obj.id).attr("checked", false);
              }
          });
  }
</script>
<%include file="FOOTER.tmpl"/>
