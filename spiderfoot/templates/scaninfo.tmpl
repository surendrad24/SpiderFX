        function vizUpdate(method) {
            s = sharedSigma
            if (method == "force") {
                $("#btn-forceatlas").addClass("active");
                $("#btn-random").removeClass("active");
                graphForceRunning = true;
                s.startForceAtlas2();
                s.refresh();
                setTimeout(function() {
                    if (graphForceRunning) {
                        s.stopForceAtlas2();
                        graphForceRunning = false;
                    }
                }, 5000);
            }

            if (method == "pause") {
                graphForceRunning = false;
                try { s.stopForceAtlas2(); } catch (e) {}
            }

            if (method == "fit") {
                try {
                    s.cameras[0].goTo({x: 0, y: 0, ratio: 1});
                    s.refresh();
                } catch (e) {}
            }

            if (method == "random") {
                $("#btn-forceatlas").removeClass("active");
                $("#btn-random").addClass("active");
                refresh();
            }

            if (method == "download") {
                s.renderers[0].snapshot({download: true});
            }
        }

