                        if (scanSummary.length == 0) {
                          $("#vbarsummary").append("<div id='scansummary-content' class='alert alert-warning'><h4>No data.</h4>If the scan is still running this section will update shortly.</div>");
                        } else {
                          sf_viz_vbar("#vbarsummary", scanSummary);
                          var sortedFamilies = scanSummary.slice(0).sort(function(a, b){ return b.counter - a.counter; }).slice(0, 5);
                          for (var f = 0; f < sortedFamilies.length; f++) {
                            var fam = sortedFamilies[f];
                            var famPct = Math.max(1, Math.round(fam.pct * 100));
                            var famName = hxEsc(unescape(fam.name));
                            var famCount = hxEsc(fam.counter);
